@model IEnumerable<UserViewModel>
@{
    ViewData["Title"] = "Index";
}

<h1>All Users</h1>
<hr />


@if (Model.Count() > 0)
{
	<table class="table table-striped table-hover">
		<thead>
			<tr>
				<th>@Html.DisplayNameFor(U => U.UserName)</th>
				<th>@Html.DisplayNameFor(U => U.DisplayName)</th>
				<th>@Html.DisplayNameFor(U => U.PhoneNumber)</th>
				<th>@Html.DisplayNameFor(U => U.Email)</th>
				<th>Roles</th>
				<th>Actions</th>
			</tr>
		</thead>
		<tbody>
			@foreach (var user in Model)
			{
				<tr>
					<td>@user.UserName</td>
					<td>@user.DisplayName</td>
					<td>@user.PhoneNumber</td>
					<td>@user.Email</td>
					<td>@string.Join(",", user.Roles.ToList())</td>
					<td>
						<a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-outline-success">Edit</a>
					</td>
				</tr>
			}
		</tbody>
	</table>
}
else
{
	<p>No roles found.</p>
}

@section Scripts {
	<partial name="_ValidationScriptsPartial" />
}

